<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/manga_header_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View android:id="@+id/true_backdrop"
        android:layout_width="match_parent" android:layout_height="140dp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" tools:background="@color/md_red_400" />

    <ImageView android:id="@+id/backdrop"
        android:layout_width="0dp" android:layout_height="0dp" android:alpha="0.2" android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/true_backdrop" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="@id/true_backdrop" />

    <com.google.android.material.card.MaterialCardView android:id="@+id/manga_cover_card"
        android:layout_width="72dp" android:layout_height="108dp" android:layout_marginStart="16dp" android:layout_marginTop="16dp"
        android:clickable="true" android:focusable="true" app:cardCornerRadius="4dp" app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="@id/true_backdrop">
        <ImageView android:id="@+id/manga_cover" android:layout_width="match_parent" android:layout_height="match_parent"
            android:contentDescription="@string/cover_of_image" android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <TextView android:id="@+id/title" style="?textAppearanceTitleMedium"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginTop="16dp" android:layout_marginEnd="16dp"
        android:ellipsize="end" android:maxLines="2" android:text="@string/title"
        android:textColor="?attr/colorOnSurface" android:textIsSelectable="false" android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toEndOf="@id/manga_cover_card"
        app:layout_constraintTop_toTopOf="@id/true_backdrop" tools:text="Manga Title" />

    <TextView android:id="@+id/manga_author" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginTop="4dp" android:layout_marginEnd="16dp"
        android:alpha="0.7" android:ellipsize="end" android:maxLines="1" android:text="@string/author"
        android:textColor="?attr/colorOnSurface" android:textIsSelectable="false" android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toEndOf="@id/manga_cover_card"
        app:layout_constraintTop_toBottomOf="@id/title" tools:text="Author" />

    <TextView android:id="@+id/manga_status" style="?textAppearanceBodySmall"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginTop="4dp" android:alpha="0.6"
        android:text="@string/unknown_status" android:textColor="?attr/colorOnSurface"
        android:textIsSelectable="false" android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/manga_cover_card" app:layout_constraintTop_toBottomOf="@id/manga_author"
        tools:text="Ongoing" tools:visibility="visible" />

    <com.google.android.material.textview.MaterialTextView android:id="@+id/manga_source"
        style="?textAppearanceBodySmall" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginTop="2dp" android:layout_marginEnd="16dp" android:alpha="0.5"
        android:ellipsize="end" android:maxLines="1" android:textColor="?attr/colorOnSurface" android:textIsSelectable="false"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toEndOf="@id/manga_cover_card"
        app:layout_constraintTop_toBottomOf="@id/manga_status" tools:text="Mangadex (EN)" />

    <!-- Chapters header label (tappable, opens bottom sheet) -->
    <LinearLayout android:id="@+id/details_expand_hint" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginTop="12dp" android:layout_marginEnd="16dp"
        android:gravity="center_vertical" android:orientation="horizontal" android:clickable="true" android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/true_backdrop">
        <TextView android:id="@+id/details_hint_text" style="?textAppearanceBodySmall"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/show_more_details" android:textColor="?attr/colorOnSurface" />
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="4dp"
            android:alpha="0.5" android:src="@drawable/ic_expand_more_24dp" app:tint="?attr/colorOnSurface" />
    </LinearLayout>

    <!-- Hidden compat views -->
    <View android:id="@+id/top_view" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.card.MaterialCardView android:id="@+id/cover_card" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.textview.MaterialTextView android:id="@+id/manga_summary_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/manga_summary" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.chip.ChipGroup android:id="@+id/manga_genres_tags" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/more_button" style="@style/Theme.Widget.Button.TextButton" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/more_bg_gradient" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/more_bg_solid" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/more_end_guide" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/more_guide" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/less_button" style="@style/Theme.Widget.Button.TextButton" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <HorizontalScrollView android:id="@+id/sub_button_scroll" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/header_button_row" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/start_reading_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/favorite_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/track_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/webview_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/share_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/button_layout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/more_button_group" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/sub_item_group" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/header_divider" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/chapter_layout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.textview.MaterialTextView android:id="@+id/chapters_title" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/filter_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.textview.MaterialTextView android:id="@+id/filters_text" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
</androidx.constraintlayout.widget.ConstraintLayout>